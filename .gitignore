# ----------------------------------------------------------------------------
# Connect_Heritage root ignore rules
# Purpose:
# - Keep this root repository lightweight
# - Avoid interference from nested cloned repositories
# ----------------------------------------------------------------------------

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Python cache / env
__pycache__/
*.py[cod]
*.so
.venv/
venv/
.env

# Logs / temp
*.log
tmp/
temp/

# Large experiment artifacts
models/**
*.pth
*.pt
*.ckpt
*.onnx
*.engine

# Dataset and generated outputs
**/data/**
**/datasets/**
**/outputs/**
**/results/**
**/wandb/**

# Safety: never track nested git metadata (backup copies etc.)
**/.git/

# Backup of old nested repositories
.git_backups/

*.pdf
*.png
*.jpg