# KenLM -> BERT best pipeline example configuration
# Copy this file and edit values for your environment.

# Required paths
COORD_CSV=/path/to/<book>/<book>_coordinate.csv
IMAGES_DIR=/path/to/<book>/images
GT_DIR=/path/to/gt_pages/<book>
CKPT=/path/to/ocr/best.pth
CLASSES=/path/to/ocr/classes.txt
BERT_MODEL=/path/to/bert/final

# Optional (defaults are in run_best_pipeline.py)
ARPA=./handchar_kenlmo3.arpa
MODEL=efficientnet_b0
IMG_SIZE=224
TOPK=5
BEAM_SIZE=5
KENLM_LAMBDA=1.6
BERT_LAMBDA=0.8
BERT_PASSES=1
DEVICE=cuda
OUT_DIR=./outputs/kenlm_then_bert/best
FONT_PATH=
